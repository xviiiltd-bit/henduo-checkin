{
  "name": "Event",
  "description": "Events shown on the Rave Destiny weekly selector.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Event title shown under the card."
    },
    "date": {
      "type": "string",
      "description": "Short event date/time label, for example Sat 23:59."
    },
    "venue": {
      "type": "string",
      "description": "Venue name shown on the card."
    },
    "genre": {
      "type": "string",
      "description": "Music genre label."
    },
    "tag": {
      "type": "string",
      "description": "Short promotional tag, for example Hidden Gem."
    },
    "description": {
      "type": "string",
      "description": "Short back-of-card event description."
    },
    "instagram_url": {
      "type": "string",
      "format": "uri",
      "description": "Instagram page URL."
    },
    "registration_url": {
      "type": "string",
      "format": "uri",
      "description": "Registration or ticket page URL."
    },
    "is_published": {
      "type": "boolean",
      "default": false,
      "description": "Only published events appear on the public selector."
    },
    "sort_order": {
      "type": "integer",
      "default": 100,
      "description": "Lower numbers appear first."
    },
    "source_id": {
      "type": "string",
      "description": "ID from the external event API, used to avoid duplicate imports."
    },
    "source_date": {
      "type": "string",
      "format": "date",
      "description": "Date used when this event was fetched from the API."
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "Original event URL from the external API."
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the event was fetched."
    }
  },
  "required": [
    "title",
    "date",
    "venue",
    "genre",
    "tag",
    "instagram_url",
    "registration_url"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "data.is_published": true
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
